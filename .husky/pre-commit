#!/bin/sh
# Pre-commit hook: Scans for accidentally committed secrets
# Compatible with Husky v9+ (no husky.sh dependency)

echo "🛡️ Running Secret Scan..."

# Get staged files (exclude common non-sensitive files)
STAGED_FILES=$(git diff --cached --name-only | grep -vE "package\.json|pnpm-lock\.yaml|\.example$|\.md$")

if [ -n "$STAGED_FILES" ]; then
  # Check for hardcoded secrets in staged changes
  # Looks for: KEY=secret, SECRET=secret, PASSWORD=secret
  # Excludes: placeholders, env var references, empty values, script variable assignments
  SECRETS_FOUND=$(git diff --cached $STAGED_FILES | grep -iE "^(PRIVATE_KEY|SECRET|API_KEY|PASSWORD|STARKNET_PRIVATE_KEY|STARKNET_KEYSTORE_PASSWORD)=[^$\{]" | grep -vE "(=['\"]?(your_|YOUR_|placeholder|<|process\.env|\$\{|^\$))" || true)

  if [ -n "$SECRETS_FOUND" ]; then
    echo "❌ ERROR: Potential Secret Leak Detected!"
    echo "--------------------------------------------------"
    echo "$SECRETS_FOUND"
    echo "--------------------------------------------------"
    echo ""
    echo "⚠️  Hardcoded secrets found in staged files."
    echo ""
    echo "✅ Safe patterns:"
    echo "   PRIVATE_KEY=your_key_here          # Placeholder"
    echo "   PRIVATE_KEY=\$PRIVATE_KEY          # Env var reference"
    echo "   PRIVATE_KEY=\${PRIVATE_KEY}        # Env var reference"
    echo "   PRIVATE_KEY=                       # Empty"
    echo ""
    echo "❌ Unsafe patterns:"
    echo "   PRIVATE_KEY=0x123abc...            # Actual key"
    echo "   PRIVATE_KEY=sk_live_...            # Actual key"
    echo ""
    echo "Please remove the secrets or use placeholders/environment variables."
    exit 1
  fi
  
  # Additional check: Look for common private key patterns (64-char hex strings)
  # Excludes comments, examples, and known safe patterns
  HEX_KEYS_FOUND=$(git diff --cached $STAGED_FILES | grep -iE "0x[0-9a-f]{64}" | grep -vE "(\/\/.*0x|\/\*.*0x|example|placeholder|account\.json|Contract Address:|Address:)" || true)
  
  if [ -n "$HEX_KEYS_FOUND" ]; then
    echo "⚠️  WARNING: Long hex strings detected (possible private keys)"
    echo "--------------------------------------------------"
    echo "$HEX_KEYS_FOUND"
    echo "--------------------------------------------------"
    echo ""
    echo "If these are private keys or secrets, please remove them."
    echo "If these are contract addresses, class hashes, or TX hashes, you can proceed."
    echo ""
    echo "Proceeding anyway (this is a warning, not an error)..."
  fi
fi

echo "✅ No secrets detected in staged files."
